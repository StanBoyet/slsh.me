<% content_for :title, "Create account — slsh.me" %>
<div class="min-h-screen flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <%= link_to root_path, class: "brand inline-flex items-center gap-2.5 mb-5" do %>
        <span class="brand-mark"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2.6" d="M17 4 7 20"/></svg></span>
        <span class="brand-word">slsh<span class="dot">.</span>me</span>
      <% end %>
      <h1 style="font-family: var(--display); font-size: 38px; font-weight: 600; letter-spacing: -0.035em; line-height: 1; margin: 0;" class="hero">
        Start <span class="marker">slashing</span>.
      </h1>
    </div>

    <%= form_with model: @user, url: registration_path, class: "card-popped p-6 space-y-5" do |f| %>
      <% if @user.errors.any? %>
        <div class="badge badge-red w-full" style="display: block; padding: 12px 14px; font-size: 13px; line-height: 1.5;">
          <% @user.errors.full_messages.each do |msg| %>
            <p><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div>
        <%= f.label :username, "Username", class: "label" %>
        <%= f.text_field :username, autofocus: true, autocomplete: "username",
            class: "input", placeholder: "Optional display name", maxlength: 30 %>
      </div>

      <div>
        <%= f.label :email_address, "Email", class: "label" %>
        <%= f.email_field :email_address, required: true, autocomplete: "email",
            class: "input", placeholder: "you@example.com" %>
      </div>

      <div>
        <%= f.label :password, "Password", class: "label" %>
        <%= f.password_field :password, required: true, autocomplete: "new-password",
            minlength: 12, class: "input", placeholder: "Min. 12 characters" %>
      </div>

      <div>
        <%= f.label :password_confirmation, "Confirm password", class: "label" %>
        <%= f.password_field :password_confirmation, required: true, autocomplete: "new-password",
            class: "input", placeholder: "••••••••" %>
      </div>

      <%= f.submit "Create account", class: "btn-tangerine w-full justify-center", style: "padding: 11px 22px; font-size: 14px;" %>
    <% end %>

    <p class="text-center text-sm mt-6" style="color: var(--ink-mid);">
      Already have an account?
      <%= link_to "Sign in", new_session_path, style: "color: var(--tangerine); font-weight: 600;" %>
    </p>
  </div>
</div>
