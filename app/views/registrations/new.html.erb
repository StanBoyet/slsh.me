<% content_for :title, "Create account — slsh.me" %>
<div class="min-h-screen flex items-center justify-center px-4">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <h1 class="text-2xl font-semibold text-zinc-900 dark:text-white">slsh.me</h1>
      <p class="text-zinc-500 dark:text-zinc-400 mt-1 text-sm">Create your account</p>
    </div>

    <%= form_with model: @user, url: registration_path, class: "card p-6 space-y-4" do |f| %>
      <% if @user.errors.any? %>
        <div class="bg-red-50 border border-red-200 dark:bg-red-500/10 dark:border-red-500/20 rounded-lg px-4 py-3 text-sm text-red-700 dark:text-red-300">
          <% @user.errors.full_messages.each do |msg| %>
            <p><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div>
        <%= f.label :username, "Username", class: "label" %>
        <%= f.text_field :username, autofocus: true, autocomplete: "username",
            class: "input", placeholder: "Optional display name", maxlength: 30 %>
      </div>

      <div>
        <%= f.label :email_address, "Email", class: "label" %>
        <%= f.email_field :email_address, required: true, autocomplete: "email",
            class: "input", placeholder: "you@example.com" %>
      </div>

      <div>
        <%= f.label :password, "Password", class: "label" %>
        <%= f.password_field :password, required: true, autocomplete: "new-password",
            minlength: 12, class: "input", placeholder: "Min. 12 characters" %>
      </div>

      <div>
        <%= f.label :password_confirmation, "Confirm password", class: "label" %>
        <%= f.password_field :password_confirmation, required: true, autocomplete: "new-password",
            class: "input", placeholder: "••••••••" %>
      </div>

      <%= f.submit "Create account", class: "btn-primary w-full justify-center py-2.5" %>
    <% end %>

    <p class="text-center text-sm text-zinc-500 mt-6">
      Already have an account?
      <%= link_to "Sign in", new_session_path, class: "text-orange-500 hover:text-orange-400 dark:text-orange-400 dark:hover:text-orange-300" %>
    </p>
  </div>
</div>
