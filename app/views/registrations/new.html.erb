<% content_for :title, "Create account — slsh.me" %>
<div class="min-h-screen flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <%= render "shared/brand", class: "mb-5" %>
      <h1 class="hero-mini">Start <span class="marker">slashing</span>.</h1>
    </div>

    <%= form_with model: @user, url: registration_path, class: "card-popped p-6 space-y-5" do |f| %>
      <% if @user.errors.any? %>
        <div class="badge badge-red w-full block px-3.5 py-3 leading-relaxed text-[13px]">
          <% @user.errors.full_messages.each do |msg| %>
            <p><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div>
        <%= f.label :username, "Username", class: "label" %>
        <%= f.text_field :username, autofocus: true, autocomplete: "username",
            class: "input", placeholder: "Optional display name", maxlength: 30 %>
      </div>

      <div>
        <%= f.label :email_address, "Email", class: "label" %>
        <%= f.email_field :email_address, required: true, autocomplete: "email",
            class: "input", placeholder: "you@example.com" %>
      </div>

      <div>
        <%= f.label :password, "Password", class: "label" %>
        <%= f.password_field :password, required: true, autocomplete: "new-password",
            minlength: 12, class: "input", placeholder: "Min. 12 characters" %>
      </div>

      <div>
        <%= f.label :password_confirmation, "Confirm password", class: "label" %>
        <%= f.password_field :password_confirmation, required: true, autocomplete: "new-password",
            class: "input", placeholder: "••••••••" %>
      </div>

      <%= f.submit "Create account", class: "btn-tangerine w-full justify-center" %>
    <% end %>

    <p class="auth-footer">
      Already have an account? <%= link_to "Sign in", new_session_path, class: "auth-link" %>
    </p>
  </div>
</div>
