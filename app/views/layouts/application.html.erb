<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) { "slsh.me — URL Shortener" } %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="utf-8">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen antialiased">
    <%# Flash messages %>
    <% if notice.present? || alert.present? %>
      <div class="fixed top-4 right-4 z-50 space-y-2" data-controller="flash">
        <% if notice.present? %>
          <div class="flex items-center gap-3 bg-emerald-500/10 border border-emerald-500/20 text-emerald-300 px-4 py-3 rounded-xl text-sm shadow-lg backdrop-blur"
               data-flash-target="message">
            <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            <%= notice %>
          </div>
        <% end %>
        <% if alert.present? %>
          <div class="flex items-center gap-3 bg-red-500/10 border border-red-500/20 text-red-300 px-4 py-3 rounded-xl text-sm shadow-lg backdrop-blur"
               data-flash-target="message">
            <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
            <%= alert %>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# Nav — only when logged in %>
    <% if authenticated? %>
      <nav class="border-b border-slate-800/60 sticky top-0 z-40 backdrop-blur bg-slate-950/80">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
          <%= link_to root_path, class: "flex items-center gap-2 group" do %>
            <span class="text-lg font-semibold tracking-tight text-white group-hover:text-violet-400 transition-colors">slsh.me</span>
          <% end %>

          <div class="flex items-center gap-2">
            <%= link_to "New link", new_link_path, class: "btn-primary text-xs py-1.5" %>
            <%= button_to "Sign out", session_path, method: :delete, class: "btn-ghost text-xs py-1.5" %>
          </div>
        </div>
      </nav>
    <% end %>

    <main class="<%= authenticated? ? "max-w-6xl mx-auto px-4 sm:px-6 py-8" : "" %>">
      <%= yield %>
    </main>
  </body>
</html>
