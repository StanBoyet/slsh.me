<%# Link card — design-system .link-card pattern.
   Composed from: .link-row (top), .link-foot (bottom with action icons).
   Action icons live bottom-right via .actions { margin-left: auto } %>
<div class="link-card row-emphasis <%= 'opacity-60' if link.archived? %>"
     style="background: var(--paper); border: 1.25px solid var(--rule); border-radius: 14px; padding: 14px 16px; transition: all 0.12s ease; position: relative;"
     onmouseover="this.style.borderColor='var(--ink)'; this.style.transform='translate(-1px,-1px)'; this.style.boxShadow='3px 3px 0 var(--ink)';"
     onmouseout="this.style.borderColor='var(--rule)'; this.style.transform='none'; this.style.boxShadow='none';">

  <%# Cover-link for analytics %>
  <%= link_to analytics_link_path(link), class: "absolute inset-0",
      style: "border-radius: 14px; z-index: 0;",
      "aria-label": "View analytics for /#{link.slug}" do %><% end %>

  <div class="flex items-center gap-4" style="position: relative; z-index: 1; pointer-events: none;">
    <%# Favicon %>
    <div style="width: 38px; height: 38px; border-radius: 10px; background: var(--canvas); border: 1px solid var(--rule-soft); flex-shrink: 0; display: grid; place-items: center; overflow: hidden;">
      <% host = (URI.parse(link.original_url).host rescue nil) %>
      <% if host %>
        <img src="https://www.google.com/s2/favicons?domain=<%= host %>&sz=32"
             style="width: 18px; height: 18px;" alt="" onerror="this.style.display='none'">
      <% end %>
    </div>

    <%# Link info %>
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 flex-wrap">
        <span style="font-family: var(--mono); font-size: 14px; font-weight: 500; color: var(--ink);">
          <%= link.domain_label %><span style="color: var(--tangerine);">/</span><%= link.slug %>
        </span>
        <% if link.campaign %>
          <%= link_to campaign_path(link.campaign),
              class: "sticker #{campaign_sticker_class(link.campaign.color)}",
              style: "pointer-events: auto; position: relative; z-index: 2;",
              title: "View campaign: #{link.campaign.name}" do %>
            <%= link.campaign.name %>
          <% end %>
        <% end %>
        <% if link.password_protected? %>
          <span class="badge badge-rose">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="4" y="11" width="16" height="11" rx="2" stroke-width="2"/><path stroke-linecap="round" stroke-width="2" d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>
            password
          </span>
        <% end %>
        <% if link.archived? %>
          <span class="badge badge-slate">archived</span>
        <% elsif !link.active? %>
          <span class="badge badge-red">inactive</span>
        <% end %>
        <% if link.expired? %>
          <span class="badge badge-slate">expired</span>
        <% elsif link.expires_soon? %>
          <span class="badge badge-amber" title="Expires <%= link.expires_at.strftime("%b %d, %Y at %H:%M") %>">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><circle cx="12" cy="12" r="9"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 7v5l3 2"/></svg>
            expires <%= time_ago_in_words(link.expires_at) %>
          </span>
        <% end %>
      </div>
      <% url_base, url_query = link.original_url.split("?", 2) %>
      <p style="font-family: var(--mono); font-size: 12px; color: var(--ink-mid); margin-top: 3px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
        <%= url_base %><% if url_query.present? %><span style="color: var(--ink-faint);">?<%= url_query %></span><% end %>
      </p>
    </div>

    <%# Click count %>
    <div class="clicks-block hidden sm:block">
      <p id="link_<%= link.id %>_clicks" class="clicks-num"><%= number_with_delimiter(link.clicks_count) %></p>
      <p class="clicks-label">click<%= "s" unless link.clicks_count == 1 %></p>
    </div>
  </div>

  <%# Foot row: timestamp + actions (always visible, right-aligned) %>
  <div class="mt-3 flex items-center gap-2.5 flex-wrap text-xs"
       style="position: relative; z-index: 1; color: var(--ink-faint); font-weight: 500;">
    <span><strong style="color: var(--ink-soft); font-weight: 600;"><%= time_ago_in_words(link.created_at) %> ago</strong></span>
    <% if link.original_url.include?("utm_source") %>
      <% utm = extract_utm_display(link.original_url) %>
      <% if utm["source"] %>
        <span>·</span>
        <span>via <strong style="color: var(--ink-soft); font-weight: 600;"><%= utm["source"] %></strong></span>
      <% end %>
    <% end %>
    <div class="flex gap-1" style="margin-left: auto; pointer-events: auto;">
      <button class="icon-btn" data-controller="copy"
              data-copy-text-value="<%= link.short_url %>"
              data-action="click->copy#copy" title="Copy short URL">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path stroke-linecap="round" stroke-linejoin="round" d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
      </button>
      <%= link_to edit_link_path(link), class: "icon-btn", title: "Edit" do %>
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
      <% end %>
      <% unless link.archived? %>
        <%= button_to link_path(link), method: :delete,
            class: "icon-btn",
            data: { turbo_confirm: "Delete this link and all its analytics?" },
            title: "Delete",
            form_class: "inline-block" do %>
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
