<div class="card p-5">
  <h3 class="text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-4">Clicks over time</h3>
  <% if @clicks_by_day.any? %>
    <%= line_chart @clicks_by_day,
        id: "clicks-chart",
        colors: ["#f97316"],
        curve: true,
        dataset: { borderWidth: 2, fill: true, backgroundColor: "rgba(249,115,22,0.08)" },
        library: { scales: { x: { grid: { color: "rgba(100,116,139,0.1)" }, ticks: { color: "#94a3b8" } },
                             y: { grid: { color: "rgba(100,116,139,0.1)" }, ticks: { color: "#94a3b8" }, beginAtZero: true } },
                   plugins: { legend: { display: false } } } %>
  <% else %>
    <p class="text-zinc-500 text-sm text-center py-8">No data for this period</p>
  <% end %>
</div>
