<% content_for :title, "Dashboard — slsh.me" %>

<div class="space-y-6">
  <%# Header %>
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
    <div>
      <h1 class="text-xl font-semibold text-slate-900 dark:text-white">My links</h1>
      <p class="text-sm text-slate-500 mt-0.5">
        <%= @links_count %> link<%= "s" unless @links_count == 1 %> &middot;
        <%= number_with_delimiter(@total_clicks) %> total clicks
      </p>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to "Domains", custom_domains_path, class: "btn-secondary text-xs py-1.5" %>
      <%= link_to "New link", new_link_path, class: "btn-primary text-xs py-1.5" %>
    </div>
  </div>

  <%# Tabs: Active / Archived %>
  <div class="flex items-center gap-1">
    <%= link_to "Active", links_path,
        class: "text-xs px-3 py-1.5 rounded-lg transition-colors #{@filter != 'archived' ? 'bg-violet-600 text-white' : 'bg-slate-100 text-slate-600 hover:text-slate-800 dark:bg-slate-800 dark:text-slate-400 dark:hover:text-slate-200'}" %>
    <% if @archived_count > 0 %>
      <%= link_to "Archived (#{@archived_count})", links_path(filter: "archived"),
          class: "text-xs px-3 py-1.5 rounded-lg transition-colors #{@filter == 'archived' ? 'bg-violet-600 text-white' : 'bg-slate-100 text-slate-600 hover:text-slate-800 dark:bg-slate-800 dark:text-slate-400 dark:hover:text-slate-200'}" %>
    <% end %>
  </div>

  <%# Search %>
  <%= form_with url: links_path(filter: @filter.presence), method: :get, class: "relative" do |f| %>
    <% if @filter.present? %>
      <%= f.hidden_field :filter, value: @filter %>
    <% end %>
    <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400 dark:text-slate-500 pointer-events-none"
         fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0"/>
    </svg>
    <%= f.search_field :q, value: params[:q], placeholder: "Search links…",
        class: "input pl-9", data: { turbo_permanent: "" } %>
  <% end %>

  <%# Links list %>
  <% if @links.any? %>
    <div class="space-y-3">
      <% @links.each do |link| %>
        <div class="card p-4 hover:border-slate-300 dark:hover:border-slate-700 transition-colors group relative cursor-pointer <%= 'opacity-60' if link.archived? %>">
          <%= link_to analytics_link_path(link), class: "absolute inset-0 rounded-2xl", aria: { label: "View analytics for /#{link.slug}" } do %><% end %>

          <div class="flex items-center gap-3">
            <%# Favicon %>
            <div class="w-8 h-8 rounded-lg bg-slate-100 border border-slate-200 dark:bg-slate-800 dark:border-slate-700 flex items-center justify-center shrink-0 overflow-hidden">
              <img src="https://www.google.com/s2/favicons?domain=<%= URI.parse(link.original_url).host rescue '' %>&sz=32"
                   class="w-5 h-5" alt="" onerror="this.style.display='none'">
            </div>

            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 flex-wrap">
                <span class="font-mono text-sm font-medium"><span class="text-slate-400 dark:text-slate-600"><%= link.domain_label %>/l/</span><span class="text-violet-600 dark:text-violet-400"><%= link.slug %></span></span>
                <% if link.archived? %>
                  <span class="badge-slate">archived</span>
                <% end %>
                <% unless link.active? || link.archived? %>
                  <span class="badge-red">inactive</span>
                <% end %>
                <% if link.expired? %>
                  <span class="badge-slate">expired</span>
                <% end %>
                <% if link.password_protected? %>
                  <span class="badge-violet">🔒 protected</span>
                <% end %>
              </div>
              <%# URL: bold base, muted UTM query string %>
              <% url_base, url_query = link.original_url.split("?", 2) %>
              <p class="text-sm truncate mt-0.5">
                <span class="text-slate-600 dark:text-slate-300 font-medium"><%= url_base %></span>
                <% if url_query.present? %>
                  <span class="text-slate-400 dark:text-slate-600">?<%= url_query %></span>
                <% end %>
              </p>
              <p class="text-xs text-slate-400 dark:text-slate-600 mt-1"><%= time_ago_in_words(link.created_at) %> ago</p>
            </div>

            <%# Stats + Actions %>
            <div class="flex items-center gap-3 shrink-0 relative z-10">
              <div class="text-right hidden sm:block">
                <p class="text-lg font-semibold text-slate-900 dark:text-white tabular-nums"><%= number_with_delimiter(link.clicks_count) %></p>
                <p class="text-xs text-slate-500">clicks</p>
              </div>

            <% unless link.archived? %>
            <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
              <button class="btn-ghost p-1.5" data-controller="copy"
                      data-copy-text-value="<%= redirect_url(link.slug) %>"
                      data-action="click->copy#copy" title="Copy short URL">
                <svg data-copy-target="icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                </svg>
              </button>
              <%= link_to analytics_link_path(link), class: "btn-ghost p-1.5", title: "Analytics" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                </svg>
              <% end %>
              <%= link_to edit_link_path(link), class: "btn-ghost p-1.5", title: "Edit" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                </svg>
              <% end %>
              <%= button_to link_path(link), method: :delete,
                  class: "btn-danger p-1.5 border-0 bg-transparent hover:bg-red-50 dark:hover:bg-red-500/10",
                  data: { turbo_confirm: "Delete this link and all its analytics?" },
                  title: "Delete" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                </svg>
              <% end %>
            </div>
            <% end %>
            </div><%# /stats+actions wrapper %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="card p-12 text-center">
      <% if @filter == "archived" %>
        <p class="text-slate-600 dark:text-slate-400 font-medium">No archived links</p>
      <% else %>
        <div class="w-12 h-12 rounded-xl bg-slate-100 dark:bg-slate-800 flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-slate-400 dark:text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
          </svg>
        </div>
        <p class="text-slate-600 dark:text-slate-400 font-medium">No links yet</p>
        <p class="text-slate-400 dark:text-slate-600 text-sm mt-1">Create your first short link to get started</p>
        <%= link_to "Create a link", new_link_path, class: "btn-primary mt-4" %>
      <% end %>
    </div>
  <% end %>
</div>
