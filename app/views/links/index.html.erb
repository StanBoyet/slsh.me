<% content_for :title, "Links — slsh.me" %>

<%= turbo_stream_from "user_#{Current.user.id}_clicks" %>

<div class="space-y-6">
  <%# Header row %>
  <div class="flex items-end justify-between gap-4 flex-col sm:flex-row">
    <div>
      <p class="small-caps mb-2">Workspace · <%= Current.user.display_name %></p>
      <h1 class="hero" style="font-size: clamp(44px, 6vw, 72px); font-weight: 600; letter-spacing: -0.04em; line-height: 0.92; margin: 0; color: var(--ink);">
        Make every <span class="marker">click</span> stick.
      </h1>
      <p class="mt-3 text-base" style="color: var(--ink-mid);">
        <%= @links_count %> link<%= "s" unless @links_count == 1 %>,
        <span id="total_clicks"><%= number_with_delimiter(@total_clicks) %></span> clicks total
      </p>
    </div>
    <%= link_to new_link_path, class: "btn-tangerine shrink-0" do %>
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.4"><path stroke-linecap="round" d="M5 12h14M12 5v14"/></svg>
      New link
    <% end %>
  </div>

  <%# Search + filter row %>
  <div class="flex items-center gap-3 flex-wrap">
    <%= form_with url: links_path(filter: @filter.presence, campaign_id: @campaign_filter), method: :get, class: "search relative flex-1 min-w-[220px]" do |f| %>
      <% if @filter.present? %>
        <%= f.hidden_field :filter, value: @filter %>
      <% end %>
      <% if @campaign_filter.present? %>
        <%= f.hidden_field :campaign_id, value: @campaign_filter %>
      <% end %>
      <svg class="search-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7" stroke-width="2"/><path stroke-linecap="round" stroke-width="2" d="m21 21-4.35-4.35"/></svg>
      <%= f.search_field :q, value: params[:q], placeholder: "Search links…",
          class: "input", data: { turbo_permanent: "" } %>
    <% end %>

    <%# Campaign filter dropdown %>
    <% if @campaigns.any? %>
      <div class="relative" data-controller="dropdown">
        <button data-action="click->dropdown#toggle"
                class="chip <%= 'chip-active' if @active_campaign %>">
          <% if @active_campaign %>
            <span class="chip-dot" style="background: <%= campaign_hex(@active_campaign.color) %>;"></span>
            <strong><%= @active_campaign.name %></strong>
          <% else %>
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z"/></svg>
            Campaign
          <% end %>
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div data-dropdown-target="menu" class="hidden absolute right-0 top-full mt-2 w-64 dropdown-panel z-50">
          <%= link_to links_path(filter: @filter.presence, q: params[:q]), class: "dropdown-item w-full" do %>
            <span class="flex-1">All links</span>
            <span class="text-xs tabular-nums" style="color: var(--ink-faint);"><%= @links_count %></span>
          <% end %>
          <div style="height: 1px; background: var(--rule-soft); margin: 4px 0;"></div>
          <% @campaigns.each do |campaign| %>
            <%= link_to links_path(campaign_id: campaign.id, filter: @filter.presence, q: params[:q]),
                class: "dropdown-item w-full",
                style: (@active_campaign&.id == campaign.id ? "background: var(--canvas);" : "") do %>
              <span style="width:8px;height:8px;border-radius:50%;border:1px solid var(--ink);background: <%= campaign_hex(campaign.color) %>;" class="shrink-0"></span>
              <span class="flex-1 truncate"><%= campaign.name %></span>
              <span class="text-xs tabular-nums" style="color: var(--ink-faint);"><%= campaign.links_count %></span>
            <% end %>
          <% end %>
          <div style="height: 1px; background: var(--rule-soft); margin: 4px 0;"></div>
          <%= link_to new_campaign_path, class: "dropdown-item w-full", style: "color: var(--tangerine); font-weight: 600;" do %>
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
            New campaign
          <% end %>
        </div>
      </div>
    <% else %>
      <%= link_to new_campaign_path, class: "chip" do %>
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
        New campaign
      <% end %>
    <% end %>

    <% if @archived_count > 0 %>
      <%= link_to links_path(filter: @filter == "archived" ? nil : "archived", campaign_id: @campaign_filter),
          class: "chip #{'chip-active' if @filter == 'archived'}" do %>
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5m8.25 3v6.75m0 0l-3-3m3 3l3-3M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z"/></svg>
        Archived <span style="color: var(--ink-faint);"><%= @archived_count %></span>
      <% end %>
    <% end %>
  </div>

  <%# Active campaign banner %>
  <% if @active_campaign %>
    <div class="camp-banner">
      <span class="emblem" style="background: <%= campaign_hex(@active_campaign.color) %>;">
        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path stroke-linecap="round" stroke-linejoin="round" d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/></svg>
      </span>
      <div style="flex:1;">
        <div class="title"><%= @active_campaign.name %></div>
        <div class="meta"><%= @active_campaign.links_count %> link<%= "s" unless @active_campaign.links_count == 1 %> · <%= number_with_delimiter(@active_campaign.computed_clicks_count) %> clicks</div>
      </div>
      <%= link_to campaign_path(@active_campaign), class: "pace" do %>
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l6-6 4 4 8-8M14 7h7v7"/></svg>
        View campaign
      <% end %>
      <%= link_to links_path(filter: @filter.presence, q: params[:q]), class: "icon-btn", title: "Clear filter" do %>
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" d="M6 6l12 12M6 18L18 6"/></svg>
      <% end %>
    </div>
  <% end %>

  <%# Links list %>
  <% if @links.any? %>
    <div class="space-y-2">
      <% @links.each do |link| %>
        <%= render "link_card", link: link %>
      <% end %>
    </div>
  <% else %>
    <div class="card-popped p-16 text-center" style="background: var(--paper);">
      <% if @filter == "archived" %>
        <p style="color: var(--ink-mid);">No archived links.</p>
        <%= link_to "Back to links", links_path, class: "btn btn-ghost mt-3 inline-block text-sm" %>
      <% else %>
        <div class="empty-mark mx-auto mb-5" style="display: grid;">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2.6" d="M17 4 7 20"/></svg>
        </div>
        <h2 class="empty-headline">Nothing here yet.<br><span class="marker">Slash</span> something.</h2>
        <p class="text-sm mt-2" style="color: var(--ink-soft);">Paste a URL, pick a campaign, ship it.</p>
        <%= link_to new_link_path, class: "btn-tangerine mt-6 inline-flex" do %>
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.4"><path stroke-linecap="round" d="M5 12h14M12 5v14"/></svg>
          Create your first link
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
