<% content_for :title, "Edit /#{@link.slug} — slsh.me" %>

<div class="max-w-2xl mx-auto space-y-6">
  <div class="flex items-center gap-3">
    <%= link_to links_path, class: "btn-ghost p-1.5" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
    <% end %>
    <div>
      <h1 class="text-xl font-semibold text-white">Edit link</h1>
      <p class="text-sm text-slate-500 font-mono">/<%= @link.slug %></p>
    </div>
  </div>

  <%= render "form", link: @link %>
</div>
