<tr id="<%= dom_id(visit) %>"
    class="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors<%= " new-visit-row" if local_assigns[:animate] %>">
  <td class="px-5 py-3 text-slate-500 dark:text-slate-400 whitespace-nowrap text-xs">
    <span class="inline-flex items-center gap-1.5">
      <%= visit.created_at.strftime("%b %d, %H:%M") %>
      <% if visit.bot? %>
        <svg class="w-3 h-3 text-slate-400 dark:text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" title="Bot"><rect x="4" y="8" width="16" height="12" rx="2"/><circle cx="9" cy="14" r="1.5"/><circle cx="15" cy="14" r="1.5"/><line x1="12" y1="2" x2="12" y2="8"/><line x1="8" y1="4" x2="16" y2="4"/></svg>
      <% end %>
    </span>
  </td>
  <td class="px-4 py-3 text-slate-700 dark:text-slate-300 whitespace-nowrap">
    <%= [visit.city, visit.country_code].compact.join(", ").presence || "—" %>
  </td>
  <td class="px-4 py-3 text-slate-700 dark:text-slate-300 whitespace-nowrap">
    <span class="inline-flex items-center gap-1.5">
      <span class="text-slate-500 dark:text-slate-400"><%= browser_icon(visit.browser.presence || "", css_class: "w-3 h-3") %></span>
      <%= visit.browser.presence || "—" %>
    </span>
  </td>
  <td class="px-4 py-3 text-slate-500 dark:text-slate-400 whitespace-nowrap">
    <span class="inline-flex items-center gap-1.5">
      <span class="text-slate-500 dark:text-slate-400"><%= os_icon(visit.os.presence || "", css_class: "w-3 h-3") %></span>
      <%= visit.os.presence || "—" %>
    </span>
  </td>
  <td class="px-4 py-3 whitespace-nowrap">
    <span class="badge-slate capitalize"><%= visit.device_type || "—" %></span>
  </td>
  <td class="px-4 py-3 text-slate-400 dark:text-slate-500 text-xs max-w-[200px] truncate">
    <%= visit.referer.presence || "Direct" %>
  </td>
</tr>
