<% content_for :title, "/#{@link.slug} analytics — slsh.me" %>

<div class="space-y-6" data-controller="analytics-refresh" data-analytics-refresh-delay-value="300">
  <%# Header %>
  <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4">
    <div class="flex items-center gap-3">
      <%= link_to links_path, class: "btn-ghost p-1.5" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
      <% end %>
      <div>
        <div class="flex items-center gap-2 flex-wrap">
          <h1 class="text-xl font-semibold font-mono"><span class="text-slate-300 dark:text-slate-700"><%= @link.domain_label %>/l</span><span class="text-slate-900 dark:text-white">/<%= @link.slug %></span></h1>
          <% unless @link.active? %><span class="badge-red">inactive</span><% end %>
          <% if @link.expired? %><span class="badge-slate">expired</span><% end %>
        </div>
        <p class="text-sm text-slate-500 truncate max-w-xs mt-0.5"><%= @link.original_url %></p>
      </div>
    </div>

    <div class="flex items-center gap-2 flex-wrap">
      <%# Copy button %>
      <button class="btn-secondary" data-controller="copy"
              data-copy-text-value="<%= @link.short_url %>"
              data-action="click->copy#copy">
        <svg data-copy-target="icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
        </svg>
        <span data-copy-target="label">Copy</span>
      </button>

      <%# QR Code %>
      <a href="<%= qr_link_path(@link, format: :svg) %>" target="_blank"
         class="btn-secondary">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z"/>
        </svg>
        QR Code
      </a>
      <%= link_to edit_link_path(@link), class: "btn-secondary" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
        </svg>
        Edit
      <% end %>
    </div>
  </div>

  <% frame_src = analytics_link_path(@link, range: @range) %>

  <%# Stats row %>
  <turbo-frame id="analytics-stats" class="block" data-analytics-refresh-target="frame" data-src="<%= frame_src %>">
    <%= render "analytics_stats" %>
  </turbo-frame>

  <%# Range selector %>
  <div class="flex items-center gap-2">
    <span class="section-title">Period:</span>
    <% [["7d", "7 days"], ["30d", "30 days"], ["90d", "90 days"]].each do |value, label| %>
      <%= link_to label, analytics_link_path(@link, range: value),
          class: "text-xs px-3 py-1.5 rounded-lg transition-colors #{@range == value ? 'bg-violet-600 text-white' : 'bg-slate-100 text-slate-600 hover:text-slate-800 dark:bg-slate-800 dark:text-slate-400 dark:hover:text-slate-200'}" %>
    <% end %>
  </div>

  <%# Clicks over time %>
  <turbo-frame id="analytics-chart" class="block" data-analytics-refresh-target="frame" data-src="<%= frame_src %>">
    <%= render "analytics_chart" %>
  </turbo-frame>

  <%# Breakdown grid %>
  <turbo-frame id="analytics-breakdowns" class="block" data-analytics-refresh-target="frame" data-src="<%= frame_src %>">
    <%= render "analytics_breakdowns" %>
  </turbo-frame>

  <%# Recent visits table — live-updating via Turbo Streams %>
  <%= turbo_stream_from "link_#{@link.id}_visits" %>

  <div class="card overflow-hidden">
    <div class="px-5 py-4 border-b border-slate-200 dark:border-slate-800 flex items-center justify-between">
      <h3 class="text-sm font-medium text-slate-700 dark:text-slate-300">Recent visits</h3>
      <span class="flex items-center gap-1.5 text-xs text-emerald-600 dark:text-emerald-400">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 dark:bg-emerald-400 animate-pulse"></span>
        Live
      </span>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-slate-200 dark:border-slate-800">
            <th class="text-left px-5 py-3 text-xs font-medium text-slate-500">Time</th>
            <th class="text-left px-4 py-3 text-xs font-medium text-slate-500">Location</th>
            <th class="text-left px-4 py-3 text-xs font-medium text-slate-500">Browser</th>
            <th class="text-left px-4 py-3 text-xs font-medium text-slate-500">OS</th>
            <th class="text-left px-4 py-3 text-xs font-medium text-slate-500">Device</th>
            <th class="text-left px-4 py-3 text-xs font-medium text-slate-500">Referrer</th>
          </tr>
        </thead>
        <tbody id="visits-table-body" class="divide-y divide-slate-100 dark:divide-slate-800/50">
          <% if @recent_visits.any? %>
            <%= render partial: "visit_row", collection: @recent_visits, as: :visit %>
          <% else %>
            <tr id="visits-empty-state">
              <td colspan="6" class="text-slate-500 text-sm text-center py-8">
                No visits recorded yet for this period.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
