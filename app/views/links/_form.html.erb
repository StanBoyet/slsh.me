<%= form_with model: link, class: "space-y-6", data: { controller: "link-form" } do |f| %>
  <% if link.errors.any? %>
    <div class="bg-red-50 border border-red-200 dark:bg-red-500/10 dark:border-red-500/20 rounded-xl px-4 py-3 text-sm text-red-700 dark:text-red-300 space-y-1">
      <% link.errors.full_messages.each do |msg| %>
        <p>&bull; <%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <%# Row 1: Destination + Short link %>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 items-start">

  <%# Section: Destination %>
  <div class="card-elevated p-5 space-y-4">
    <h2 class="section-title">Destination</h2>

    <div data-controller="utm">
      <div>
        <%= f.label :original_url, "Destination URL", class: "label" %>
        <%= f.url_field :original_url, required: true, placeholder: "https://example.com/your-long-url",
            class: "input font-mono text-xs",
            data: { utm_target: "url", action: "input->utm#updatePreview" } %>
      </div>

      <%# UTM builder %>
      <details class="mt-3 group">
        <summary class="text-xs text-slate-500 hover:text-violet-600 dark:hover:text-violet-400 cursor-pointer select-none flex items-center gap-1 transition-colors">
          <svg class="w-3.5 h-3.5 transition-transform group-open:rotate-90" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
          </svg>
          UTM parameters
        </summary>
        <div class="mt-3 grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div>
            <label class="label">Source</label>
            <input type="text" placeholder="e.g. twitter"
                   class="input text-xs" data-utm-target="source" data-action="input->utm#updatePreview">
          </div>
          <div>
            <label class="label">Medium</label>
            <input type="text" placeholder="e.g. social"
                   class="input text-xs" data-utm-target="medium" data-action="input->utm#updatePreview">
          </div>
          <div>
            <label class="label">Campaign</label>
            <input type="text" placeholder="e.g. launch"
                   class="input text-xs" data-utm-target="campaign" data-action="input->utm#updatePreview">
          </div>
          <div>
            <label class="label">Content</label>
            <input type="text" placeholder="optional"
                   class="input text-xs" data-utm-target="content" data-action="input->utm#updatePreview">
          </div>
        </div>
        <div class="mt-3" data-utm-target="preview" style="display:none">
          <label class="label">Preview</label>
          <p class="font-mono text-xs text-slate-500 dark:text-slate-400 bg-slate-50 border border-slate-200 dark:bg-slate-950 dark:border-slate-800 rounded-lg p-3 break-all" data-utm-target="previewText"></p>
        </div>
      </details>
    </div>
  </div>

  <%# Section: Short link %>
  <div class="card-elevated p-5 space-y-4">
    <h2 class="section-title">Short link</h2>

    <% domains = Current.user.custom_domains.order(:domain) %>

    <% if link.persisted? %>
      <div>
        <label class="label">Short URL</label>
        <div class="flex items-center px-3 h-9 bg-slate-100 border border-slate-300 dark:bg-slate-800 dark:border-slate-700 rounded-lg text-slate-500 text-sm font-mono">
          <%= link.domain_label %>/<%= link.slug %>
        </div>
        <p class="text-xs mt-1.5 text-slate-400 dark:text-slate-600">Domain and slug cannot be changed after creation.</p>
      </div>
    <% else %>
      <div data-controller="slug-check" data-slug-check-exists-url-value="<%= links_path(format: :json) %>">
        <label class="label">Custom slug <span class="text-slate-400 dark:text-slate-600 font-normal">(leave blank to auto-generate)</span></label>
        <div class="flex items-center gap-0">
          <% if domains.any? %>
            <div class="relative shrink-0">
              <%= f.select :custom_domain_id,
                  [["slsh.me/", nil]] + domains.map { |d| ["#{d.domain}/", d.id] },
                  {}, class: "h-9 bg-slate-100 border border-r-0 border-slate-300 dark:bg-slate-800 dark:border-slate-700 rounded-l-lg text-slate-500 text-sm pl-3 pr-7 appearance-none cursor-pointer focus:outline-none font-mono" %>
              <svg class="pointer-events-none absolute right-2 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </div>
          <% else %>
            <span class="flex items-center px-3 h-9 bg-slate-100 border border-r-0 border-slate-300 dark:bg-slate-800 dark:border-slate-700 rounded-l-lg text-slate-500 text-sm shrink-0 font-mono">
              slsh.me/
            </span>
          <% end %>
          <%= f.text_field :slug, placeholder: "my-custom-slug",
              class: "input rounded-l-none font-mono text-sm flex-1",
              data: { slug_check_target: "input", action: "input->slug-check#check" } %>
        </div>
        <p class="text-xs mt-1.5 hidden text-red-500 dark:text-red-400" data-slug-check-target="taken">That slug is already taken.</p>
        <p class="text-xs mt-1.5 text-slate-400 dark:text-slate-600">Letters, numbers, hyphens and underscores only.</p>
      </div>
    <% end %>
  </div>

  </div><%# /Row 1 grid %>

  <%# Row 2: Social preview + Advanced %>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 items-start">

  <%# Section: Social preview %>
  <div class="card-elevated p-5 space-y-4">
    <div>
      <h2 class="section-title">Social preview (OpenGraph)</h2>
      <p class="text-xs text-slate-500 mt-0.5">Override how this link appears when shared on social media.</p>
    </div>
    <div class="flex justify-end -mt-2" data-controller="og-fetch" data-og-fetch-url-value="<%= fetch_og_links_path %>">
      <button type="button" data-action="click->og-fetch#fetch" data-og-fetch-target="button"
              class="text-xs text-slate-400 hover:text-violet-600 dark:hover:text-violet-400 transition-colors cursor-pointer flex items-center gap-1 disabled:opacity-50">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
        <span>Fetch from URL</span>
        <svg class="w-3 h-3 animate-spin hidden" data-og-fetch-target="spinner" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
      </button>
    </div>

    <div>
      <%= f.label :title, "Title", class: "label" %>
      <%= f.text_field :title, placeholder: @link.persisted? ? @link.og_title : "Custom title for social share",
          class: "input" %>
    </div>
    <div>
      <%= f.label :description, "Description", class: "label" %>
      <%= f.text_area :description, placeholder: @link.persisted? ? @link.og_description : "Short description for social preview",
          rows: 2, class: "input resize-none" %>
    </div>
    <div data-controller="image-preview">
      <%= f.label :og_image, "Social image", class: "label" %>
      <div class="mb-2 rounded-lg overflow-hidden border border-slate-200 dark:border-slate-800 inline-block">
        <% if @link.og_image.attached? %>
          <%= image_tag @link.og_image.variant(resize_to_limit: [ 400, 210 ]),
              class: "block max-w-[400px]",
              data: { image_preview_target: "preview" } %>
        <% else %>
          <img src="" class="block max-w-[400px] hidden" data-image-preview-target="preview">
        <% end %>
      </div>
      <div class="flex items-center gap-3">
        <%= f.file_field :og_image, accept: "image/jpeg,image/png,image/webp",
            data: { image_preview_target: "input", action: "change->image-preview#preview" },
            class: "text-xs text-slate-500 file:mr-3 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-medium file:bg-slate-100 file:text-slate-700 dark:file:bg-slate-800 dark:file:text-slate-300 hover:file:bg-slate-200 dark:hover:file:bg-slate-700 file:cursor-pointer file:transition-colors" %>
        <input type="hidden" name="link[remove_og_image]" value="" data-image-preview-target="remove">
        <button type="button" data-action="click->image-preview#removeImage"
                data-image-preview-target="removeBtn"
                class="text-xs text-red-500 hover:text-red-700 dark:hover:text-red-400 transition-colors cursor-pointer <%= 'hidden' unless @link.og_image.attached? %>">Remove</button>
      </div>
      <p class="text-xs text-slate-400 dark:text-slate-600 mt-1">JPG, PNG or WebP. Recommended: 1200×630px</p>
    </div>
  </div>

  <%# Section: Advanced %>
  <div class="card-elevated p-5 space-y-4">
    <h2 class="section-title">Advanced</h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <%= f.label :expires_at, "Expires at", class: "label" %>
        <%= f.datetime_local_field :expires_at, class: "input text-sm",
            value: link.expires_at&.strftime("%Y-%m-%dT%H:%M") %>
        <p class="text-xs text-slate-400 dark:text-slate-600 mt-1">Leave blank for no expiry</p>
      </div>
      <div>
        <%= f.label :max_clicks, "Click limit", class: "label" %>
        <%= f.number_field :max_clicks, min: 1, placeholder: "e.g. 1000",
            class: "input" %>
        <p class="text-xs text-slate-400 dark:text-slate-600 mt-1">Deactivates after N clicks</p>
      </div>
    </div>

    <div>
      <%= f.label :password, "Password protect", class: "label" %>
      <%= f.password_field :password, placeholder: "Set a password (optional)",
          autocomplete: "new-password", class: "input" %>
      <% if link.persisted? && link.password_protected? %>
        <p class="text-xs text-slate-500 mt-1">Link is currently password protected. Enter a new password to change it, or leave blank to keep it.</p>
      <% end %>
    </div>

    <% if link.persisted? %>
      <div class="flex items-center gap-3">
        <%= f.check_box :active, class: "w-4 h-4 rounded border-slate-300 bg-white text-violet-600 focus:ring-violet-500 dark:border-slate-700 dark:bg-slate-900 dark:focus:ring-offset-slate-950" %>
        <%= f.label :active, "Link is active", class: "text-sm text-slate-700 dark:text-slate-300 cursor-pointer" %>
      </div>
    <% end %>
  </div>

  </div><%# /Row 2 grid %>

  <div class="flex gap-3 justify-end">
    <%= link_to "Cancel", links_path, class: "btn-secondary" %>
    <%= f.submit link.persisted? ? "Save changes" : "Create link", class: "btn-primary" %>
  </div>
<% end %>
