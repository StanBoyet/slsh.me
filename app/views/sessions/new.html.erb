<% content_for :title, "Sign in — slsh.me" %>
<div class="min-h-screen flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <%= render "shared/brand", class: "mb-5" %>
      <h1 class="hero-mini">Welcome <span class="marker">back</span>.</h1>
    </div>

    <%= form_with url: session_path, class: "card-popped p-6 space-y-5" do |f| %>
      <div>
        <%= f.label :email_address, "Email", class: "label" %>
        <%= f.email_field :email_address, required: true, autofocus: true, autocomplete: "email",
            class: "input", placeholder: "you@example.com", value: params[:email_address] %>
      </div>

      <div>
        <div class="flex items-center justify-between mb-1.5">
          <%= f.label :password, "Password", class: "label !mb-0" %>
          <%= link_to "Forgot?", new_password_path, class: "auth-link" %>
        </div>
        <%= f.password_field :password, required: true, autocomplete: "current-password",
            maxlength: 72, class: "input", placeholder: "••••••••" %>
      </div>

      <%= f.submit "Sign in", class: "btn-tangerine w-full justify-center" %>
    <% end %>

    <p class="auth-footer">
      No account? <%= link_to "Create one", new_registration_path, class: "auth-link" %>
    </p>
  </div>
</div>
