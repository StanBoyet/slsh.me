<% content_for :title, "Sign in — slsh.me" %>
<div class="min-h-screen flex items-center justify-center px-4">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <h1 class="text-2xl font-semibold text-slate-900 dark:text-white">slsh.me</h1>
      <p class="text-slate-500 dark:text-slate-400 mt-1 text-sm">Sign in to your account</p>
    </div>

    <%= form_with url: session_path, class: "card p-6 space-y-4" do |f| %>
      <div>
        <%= f.label :email_address, "Email", class: "label" %>
        <%= f.email_field :email_address, required: true, autofocus: true, autocomplete: "email",
            class: "input", placeholder: "you@example.com", value: params[:email_address] %>
      </div>

      <div>
        <div class="flex items-center justify-between mb-1.5">
          <%= f.label :password, "Password", class: "label mb-0" %>
          <%= link_to "Forgot?", new_password_path, class: "text-xs text-violet-600 hover:text-violet-500 dark:text-violet-400 dark:hover:text-violet-300" %>
        </div>
        <%= f.password_field :password, required: true, autocomplete: "current-password",
            maxlength: 72, class: "input", placeholder: "••••••••" %>
      </div>

      <%= f.submit "Sign in", class: "btn-primary w-full justify-center py-2.5" %>
    <% end %>

    <p class="text-center text-sm text-slate-500 mt-6">
      No account?
      <%= link_to "Create one", new_registration_path, class: "text-violet-600 hover:text-violet-500 dark:text-violet-400 dark:hover:text-violet-300" %>
    </p>
  </div>
</div>
