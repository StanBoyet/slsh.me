<% content_for :title, "Set new password — slsh.me" %>
<div class="min-h-screen flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <%= render "shared/brand", class: "mb-5" %>
      <h1 class="hero-mini sm">Set a new <span class="marker">password</span>.</h1>
    </div>

    <%= form_with url: password_path(params[:token]), method: :put, class: "card-popped p-6 space-y-5" do |f| %>
      <div>
        <%= f.label :password, "New password", class: "label" %>
        <%= f.password_field :password, required: true, autocomplete: "new-password",
            maxlength: 72, class: "input", placeholder: "Min. 12 characters" %>
      </div>
      <div>
        <%= f.label :password_confirmation, "Confirm password", class: "label" %>
        <%= f.password_field :password_confirmation, required: true, autocomplete: "new-password",
            maxlength: 72, class: "input", placeholder: "••••••••" %>
      </div>
      <%= f.submit "Update password", class: "btn-tangerine w-full justify-center" %>
    <% end %>
  </div>
</div>
