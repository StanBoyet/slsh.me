<% content_for :title, "Reset password — slsh.me" %>
<div class="min-h-screen flex items-center justify-center px-4">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <h1 class="text-2xl font-semibold text-zinc-900 dark:text-white">slsh.me</h1>
      <p class="text-zinc-500 dark:text-zinc-400 mt-1 text-sm">Reset your password</p>
    </div>

    <%= form_with url: passwords_path, class: "card p-6 space-y-4" do |f| %>
      <div>
        <%= f.label :email_address, "Email address", class: "label" %>
        <%= f.email_field :email_address, required: true, autofocus: true, autocomplete: "email",
            class: "input", placeholder: "you@example.com", value: params[:email_address] %>
      </div>
      <%= f.submit "Send reset instructions", class: "btn-primary w-full justify-center py-2.5" %>
    <% end %>

    <p class="text-center text-sm text-zinc-500 mt-6">
      <%= link_to "Back to sign in", new_session_path, class: "text-orange-500 hover:text-orange-400 dark:text-orange-400 dark:hover:text-orange-300" %>
    </p>
  </div>
</div>
