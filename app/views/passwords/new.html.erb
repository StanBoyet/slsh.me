<% content_for :title, "Reset password — slsh.me" %>
<div class="min-h-screen flex items-center justify-center px-4">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <h1 class="text-2xl font-semibold text-white">slsh.me</h1>
      <p class="text-slate-400 mt-1 text-sm">Reset your password</p>
    </div>

    <%= form_with url: passwords_path, class: "card p-6 space-y-4" do |f| %>
      <div>
        <%= f.label :email_address, "Email address", class: "label" %>
        <%= f.email_field :email_address, required: true, autofocus: true, autocomplete: "email",
            class: "input", placeholder: "you@example.com", value: params[:email_address] %>
      </div>
      <%= f.submit "Send reset instructions", class: "btn-primary w-full justify-center py-2.5" %>
    <% end %>

    <p class="text-center text-sm text-slate-500 mt-6">
      <%= link_to "Back to sign in", new_session_path, class: "text-violet-400 hover:text-violet-300" %>
    </p>
  </div>
</div>
