<% content_for :title, "Reset password — slsh.me" %>
<div class="min-h-screen flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <%= link_to root_path, class: "brand inline-flex items-center gap-2.5 mb-5" do %>
        <span class="brand-mark"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2.6" d="M17 4 7 20"/></svg></span>
        <span class="brand-word">slsh<span class="dot">.</span>me</span>
      <% end %>
      <h1 style="font-family: var(--display); font-size: 34px; font-weight: 600; letter-spacing: -0.035em; line-height: 1; margin: 0;" class="hero">
        Reset your <span class="marker">password</span>.
      </h1>
    </div>

    <%= form_with url: passwords_path, class: "card-popped p-6 space-y-5" do |f| %>
      <div>
        <%= f.label :email_address, "Email address", class: "label" %>
        <%= f.email_field :email_address, required: true, autofocus: true, autocomplete: "email",
            class: "input", placeholder: "you@example.com", value: params[:email_address] %>
      </div>
      <%= f.submit "Send reset instructions", class: "btn-tangerine w-full justify-center", style: "padding: 11px 22px; font-size: 14px;" %>
    <% end %>

    <p class="text-center text-sm mt-6" style="color: var(--ink-mid);">
      <%= link_to "← Back to sign in", new_session_path, style: "color: var(--tangerine); font-weight: 600;" %>
    </p>
  </div>
</div>
