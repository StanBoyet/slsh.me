<%= render layout: "settings/layout" do %>
  <div class="space-y-6">
    <div>
      <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Custom domains</h2>
      <p class="text-sm text-slate-500 mt-0.5">Manage domains for your short links.</p>
    </div>

    <%# Add domain form %>
    <div class="card p-5 space-y-4">
      <h3 class="section-title">Add a domain</h3>
      <p class="text-xs text-slate-500">Your clients' short links will be served from this domain.</p>

      <%= form_with model: @custom_domain, url: custom_domains_path, class: "space-y-3" do |f| %>
        <% if @custom_domain.errors.any? %>
          <div class="bg-red-50 border border-red-200 dark:bg-red-500/10 dark:border-red-500/20 rounded-lg px-4 py-3 text-sm text-red-700 dark:text-red-300">
            <% @custom_domain.errors.full_messages.each do |msg| %>
              <p><%= msg %></p>
            <% end %>
          </div>
        <% end %>

        <div>
          <%= f.label :domain, "Domain", class: "label" %>
          <%= f.text_field :domain, placeholder: "links.example.com", class: "input font-mono text-sm", required: true %>
        </div>

        <%= f.submit "Add domain", class: "btn-primary" %>
      <% end %>
    </div>

    <%# Existing domains %>
    <% if @custom_domains.any? %>
      <div class="space-y-3">
        <% @custom_domains.each do |domain| %>
          <div class="card p-4 flex items-center justify-between gap-4">
            <div class="min-w-0">
              <p class="font-mono text-sm font-medium text-slate-900 dark:text-white truncate"><%= domain.domain %></p>
              <p class="text-xs text-slate-500 mt-0.5">
                <%= domain.links.not_archived.count %> active link<%= "s" unless domain.links.not_archived.count == 1 %>
              </p>
            </div>

            <div class="flex items-center gap-2 shrink-0">
              <% if domain.verified? %>
                <span class="badge-green">verified</span>
              <% else %>
                <span class="badge-slate">pending</span>
                <%= form_with url: check_custom_domain_path(domain), method: :post do %>
                  <button type="submit" class="btn-secondary text-xs py-1 group disabled:opacity-50"
                          data-turbo-submits-with='<svg class="w-3.5 h-3.5 inline animate-spin -mt-px" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg> Checking…'>
                    Check now
                  </button>
                <% end %>
              <% end %>

              <%= button_to custom_domain_path(domain), method: :delete,
                  class: "btn-danger text-xs py-1.5",
                  data: { turbo_confirm: "Remove this domain? All its links will be archived." } do %>
                Remove
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# DNS instructions %>
    <div class="card p-5 space-y-3">
      <h3 class="section-title">DNS setup</h3>
      <p class="text-sm text-slate-600 dark:text-slate-400">
        For each custom domain, create a <strong>CNAME</strong> record pointing to:
      </p>
      <div class="bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-lg p-3">
        <code class="text-sm font-mono text-violet-600 dark:text-violet-400">slsh-me.fly.dev</code>
      </div>
      <p class="text-xs text-slate-500">
        After adding the CNAME, TLS certificates are provisioned automatically.
        It may take a few minutes for the certificate to be issued.
      </p>
    </div>
  </div>
<% end %>
