<%= render layout: "settings/layout" do %>
  <div class="space-y-6">
    <div>
      <h2 class="text-lg font-semibold text-zinc-900 dark:text-white">Custom domains</h2>
      <p class="text-sm text-zinc-500 mt-0.5">Manage domains for your short links.</p>
    </div>

    <%# Add domain form %>
    <div class="card p-5 space-y-4">
      <h3 class="section-title">Add a domain</h3>
      <p class="text-xs text-zinc-500">Your clients' short links will be served from this domain.</p>

      <%= form_with model: @custom_domain, url: custom_domains_path, class: "space-y-3" do |f| %>
        <% if @custom_domain.errors.any? %>
          <div class="bg-red-50 border border-red-200 dark:bg-red-500/10 dark:border-red-500/20 rounded-lg px-4 py-3 text-sm text-red-700 dark:text-red-300">
            <% @custom_domain.errors.full_messages.each do |msg| %>
              <p><%= msg %></p>
            <% end %>
          </div>
        <% end %>

        <div>
          <%= f.label :domain, "Domain", class: "label" %>
          <%= f.text_field :domain, placeholder: "links.example.com", class: "input font-mono text-sm", required: true %>
        </div>

        <%= f.submit "Add domain", class: "btn-primary" %>
      <% end %>
    </div>

    <%# Existing domains %>
    <% if @custom_domains.any? %>
      <div class="space-y-3">
        <% @custom_domains.each do |domain| %>
          <div class="card p-4 flex items-center justify-between gap-4">
            <div class="min-w-0">
              <p class="font-mono text-sm font-medium text-zinc-900 dark:text-white truncate"><%= domain.domain %></p>
              <p class="text-xs text-zinc-500 mt-0.5">
                <%= domain.links.not_archived.count %> active link<%= "s" unless domain.links.not_archived.count == 1 %>
              </p>
            </div>

            <div class="flex items-center gap-2 shrink-0">
              <%= button_to custom_domain_path(domain), method: :delete,
                  class: "btn-danger text-xs py-1.5",
                  data: { turbo_confirm: "Remove this domain? All its links will be archived." } do %>
                Remove
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# DNS instructions %>
    <div class="card p-5 space-y-3">
      <h3 class="section-title">DNS setup</h3>
      <p class="text-sm text-zinc-600 dark:text-zinc-400">
        For each custom domain, create a <strong>CNAME</strong> record pointing to:
      </p>
      <div class="bg-zinc-50 dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 rounded-lg p-3">
        <code class="text-sm font-mono text-orange-500 dark:text-orange-400">cname.slsh.me</code>
      </div>
      <p class="text-xs text-zinc-500">
        TLS is issued automatically on the first visit — no waiting, no flipping a switch.
        Just add the CNAME and open the domain in a browser.
      </p>
      <p class="text-xs text-zinc-500">
        <strong>Don't CNAME to <code>slsh.me</code> directly</strong> — that record is proxied behind Cloudflare
        and won't accept your hostname. <code>cname.slsh.me</code> is the DNS-only anchor that resolves to
        the origin.
      </p>
    </div>
  </div>
<% end %>
