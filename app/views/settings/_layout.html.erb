<% content_for :title, "Settings — slsh.me" %>

<div class="flex flex-col sm:flex-row gap-8">
  <%# Sidebar %>
  <nav class="sm:w-48 shrink-0">
    <div class="flex sm:flex-col gap-1">
      <%= link_to "Profile", profile_settings_path,
          class: "text-sm px-3 py-2 rounded-lg transition-colors #{action_name == 'profile' ? 'bg-zinc-100 dark:bg-zinc-800 text-zinc-900 dark:text-white font-medium' : 'text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white hover:bg-zinc-50 dark:hover:bg-zinc-800/50'}" %>
      <%= link_to "Domains", domains_settings_path,
          class: "text-sm px-3 py-2 rounded-lg transition-colors #{action_name == 'domains' ? 'bg-zinc-100 dark:bg-zinc-800 text-zinc-900 dark:text-white font-medium' : 'text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white hover:bg-zinc-50 dark:hover:bg-zinc-800/50'}" %>
    </div>
  </nav>

  <%# Content %>
  <div class="flex-1 min-w-0 max-w-2xl">
    <%= yield %>
  </div>
</div>
