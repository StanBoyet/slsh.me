  </section>

  <!-- How it works -->
  <section class="relative z-10 max-w-3xl mx-auto px-6 py-16 md:py-28">
    <div class="text-center mb-12">
      <h2 class="font-display text-2xl md:text-3xl font-bold tracking-tight">Three steps. That's it.</h2>
      <p class="mt-2 text-sm text-zinc-500 dark:text-zinc-400">No setup wizards, no config files, no friction.</p>
    </div>

    <div class="space-y-6">
      <!-- Step 1 -->
      <div class="flex gap-5 items-start p-5 rounded-2xl bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800">
        <span class="shrink-0 w-8 h-8 rounded-lg bg-violet-100 dark:bg-violet-900/30 flex items-center justify-center font-display font-bold text-sm text-violet-600 dark:text-violet-400">1</span>
        <div class="flex-1 min-w-0">
          <h3 class="font-display font-bold text-sm">Paste your URL</h3>
          <p class="text-xs text-zinc-500 dark:text-zinc-400 mt-1 leading-relaxed">Drop in any link. Pick a custom slug or let us generate one. Add a password, expiry, or OG preview if you want — all optional.</p>
          <div class="mt-3 flex items-center gap-0 max-w-sm">
            <div class="flex-1 px-3 py-1.5 bg-zinc-50 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 rounded-l-lg font-mono text-[11px] text-zinc-400 truncate">https://example.com/very/long/path</div>
            <div class="px-3 py-1.5 bg-violet-600 text-white text-[11px] font-semibold rounded-r-lg">Shorten</div>
          </div>
        </div>
      </div>

      <!-- Step 2 -->
      <div class="flex gap-5 items-start p-5 rounded-2xl bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800">
        <span class="shrink-0 w-8 h-8 rounded-lg bg-cyan-100 dark:bg-cyan-900/30 flex items-center justify-center font-display font-bold text-sm text-cyan-600 dark:text-cyan-400">2</span>
        <div class="flex-1 min-w-0">
          <h3 class="font-display font-bold text-sm">Share it</h3>
          <p class="text-xs text-zinc-500 dark:text-zinc-400 mt-1 leading-relaxed">Copy your short link or download the QR code. Works everywhere — social, email, print, SMS. Your domain or ours.</p>
          <div class="mt-3 inline-flex items-center gap-2 px-3 py-1.5 bg-zinc-50 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 rounded-lg">
            <span class="font-mono text-[11px]"><span class="text-zinc-400">slsh.me/</span><span class="text-violet-600 dark:text-violet-400 font-medium">spring26</span></span>
            <span class="text-[10px] text-emerald-600 dark:text-emerald-400 font-medium">Copied!</span>
          </div>
        </div>
      </div>

      <!-- Step 3 -->
      <div class="flex gap-5 items-start p-5 rounded-2xl bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800">
        <span class="shrink-0 w-8 h-8 rounded-lg bg-amber-100 dark:bg-amber-900/30 flex items-center justify-center font-display font-bold text-sm text-amber-600 dark:text-amber-400">3</span>
        <div class="flex-1 min-w-0">
          <h3 class="font-display font-bold text-sm">Watch it work</h3>
          <p class="text-xs text-zinc-500 dark:text-zinc-400 mt-1 leading-relaxed">Clicks show up in real time. See where your audience is, what they use, and where they came from. No setup required.</p>
          <div class="mt-3 flex items-center gap-3 text-[11px]">
            <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span><span class="text-emerald-600 dark:text-emerald-400 font-medium">Live</span></span>
            <span class="text-zinc-400 dark:text-zinc-600">142 clicks</span>
            <span class="text-zinc-400 dark:text-zinc-600">12 countries</span>
            <span class="text-zinc-400 dark:text-zinc-600">4 devices</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="relative z-10 max-w-4xl mx-auto px-6 py-16 md:py-28">
    <p class="text-center text-xs font-mono font-medium text-zinc-400 dark:text-zinc-600 uppercase tracking-widest mb-10">Perfect for</p>

    <div class="space-y-3">
      <div class="flex items-center gap-5 p-6 rounded-2xl bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800">
        <div class="shrink-0 w-9 h-9 rounded-lg border border-zinc-200 dark:border-zinc-800 flex items-center justify-center">
          <svg class="w-4 h-4 text-zinc-400 dark:text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 110-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.253.962.584 1.892.985 2.783.247.55.06 1.21-.463 1.511l-.657.38c-.551.318-1.26.117-1.527-.461a20.845 20.845 0 01-1.44-4.282m3.102.069a18.03 18.03 0 01-.59-4.59c0-1.586.205-3.124.59-4.59m0 9.18a23.848 23.848 0 018.835 2.535M10.34 6.66a23.847 23.847 0 008.835-2.535m0 0A23.74 23.74 0 0018.795 3m.38 1.125a23.91 23.91 0 011.014 5.395m-1.014 8.855c-.118.38-.245.754-.38 1.125m.38-1.125a23.91 23.91 0 001.014-5.395m0-3.46c.495.413.811 1.035.811 1.73 0 .695-.316 1.317-.811 1.73m0-3.46a24.347 24.347 0 010 3.46"/></svg>
        </div>
        <div class="flex-1 min-w-0">
          <p class="font-mono text-[10px] text-zinc-400 dark:text-zinc-600 uppercase tracking-widest">Marketers</p>
          <h3 class="font-display font-bold text-sm leading-snug mt-1">Know exactly what converts</h3>
          <p class="mt-1 text-xs text-zinc-500 dark:text-zinc-400 leading-relaxed">UTM-tagged short links with click attribution by campaign, source, and medium.</p>
        </div>
        <p class="font-mono text-[11px] text-zinc-300 dark:text-zinc-700 hidden md:block shrink-0">slsh.me/<span class="text-zinc-500 dark:text-zinc-400">launch?utm_source=tw</span></p>
      </div>
      <div class="flex items-center gap-5 p-6 rounded-2xl bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800">
        <div class="shrink-0 w-9 h-9 rounded-lg border border-zinc-200 dark:border-zinc-800 flex items-center justify-center">
          <svg class="w-4 h-4 text-zinc-400 dark:text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"/></svg>
        </div>
        <div class="flex-1 min-w-0">
          <p class="font-mono text-[10px] text-zinc-400 dark:text-zinc-600 uppercase tracking-widest">Developers</p>
          <h3 class="font-display font-bold text-sm leading-snug mt-1">Integrate in one call</h3>
          <p class="mt-1 text-xs text-zinc-500 dark:text-zinc-400 leading-relaxed">REST API, webhook events, custom domains via DNS. Build it into your stack.</p>
        </div>
        <p class="font-mono text-[11px] text-zinc-300 dark:text-zinc-700 hidden md:block shrink-0">curl -X POST <span class="text-zinc-500 dark:text-zinc-400">/api/links</span></p>
      </div>
      <div class="flex items-center gap-5 p-6 rounded-2xl bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800">
        <div class="shrink-0 w-9 h-9 rounded-lg border border-zinc-200 dark:border-zinc-800 flex items-center justify-center">
          <svg class="w-4 h-4 text-zinc-400 dark:text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z"/></svg>
        </div>
        <div class="flex-1 min-w-0">
          <p class="font-mono text-[10px] text-zinc-400 dark:text-zinc-600 uppercase tracking-widest">Creators</p>
          <h3 class="font-display font-bold text-sm leading-snug mt-1">Clean links that tell a story</h3>
          <p class="mt-1 text-xs text-zinc-500 dark:text-zinc-400 leading-relaxed">Custom slugs, branded domains, and social previews you control.</p>
        </div>
        <p class="font-mono text-[11px] text-zinc-300 dark:text-zinc-700 hidden md:block shrink-0">go.studio/<span class="text-zinc-500 dark:text-zinc-400">new-collection</span></p>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="relative z-10 max-w-5xl mx-auto px-6 pb-10">
    <div class="border-t border-zinc-200 dark:border-zinc-800 pt-8 text-center space-y-4">
      <p class="font-mono text-sm text-zinc-400 dark:text-zinc-600">Life's too short for long URLs.</p>
      <div class="flex items-center justify-center gap-4 text-xs">
        <a href="<%= app_url("/registration/new") %>" class="text-violet-600 dark:text-violet-400 hover:text-violet-500 font-medium transition-colors">Get started</a>
        <span class="text-zinc-300 dark:text-zinc-700">/</span>
        <a href="<%= app_url("/session/new") %>" class="text-zinc-500 hover:text-zinc-900 dark:hover:text-white transition-colors">Sign in</a>
      </div>
      <p class="text-[11px] text-zinc-300 dark:text-zinc-700">&copy; 2026 slsh.me</p>
    </div>
  </footer>

  <!-- Theme toggle -->
  <button id="theme-toggle"
          class="fixed bottom-4 left-4 z-50 p-2 rounded-full bg-white dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 shadow-md hover:bg-zinc-50 dark:hover:bg-zinc-700 transition-colors cursor-pointer"
          aria-label="Toggle theme">
    <svg class="w-4 h-4 text-zinc-500 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
    <svg class="w-4 h-4 text-zinc-500 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
  </button>

  <script>
    // Theme toggle
    (function() {
      const html = document.documentElement;
      const toggle = document.getElementById('theme-toggle');
      const stored = localStorage.getItem('theme');
      if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        html.classList.add('dark');
      }
      toggle.addEventListener('click', () => {
        html.classList.toggle('dark');
        localStorage.setItem('theme', html.classList.contains('dark') ? 'dark' : 'light');
      });
    })();

  </script>
</body>
</html>
