<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>slsh.me — Paste. Slash. Share.</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          fontFamily: {
            display: ['Bricolage Grotesque', 'serif'],
            sans: ['Plus Jakarta Sans', 'system-ui', 'sans-serif'],
            mono: ['Fira Code', 'monospace'],
          },
        }
      }
    }
  </script>
  <style>
    /* Hero word reveal */
    @keyframes wordReveal {
      0% { opacity: 0; transform: translateY(40px) rotateX(-15deg); filter: blur(8px); }
      100% { opacity: 1; transform: translateY(0) rotateX(0deg); filter: blur(0); }
    }
    .word-reveal {
      opacity: 0;
      animation: wordReveal 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    .word-1 { animation-delay: 0.2s; }
    .word-2 { animation-delay: 0.5s; }
    .word-3 { animation-delay: 0.8s; }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .fade-up {
      opacity: 0;
      animation: fadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    .fd1 { animation-delay: 1.1s; }
    .fd2 { animation-delay: 1.3s; }
    .fd3 { animation-delay: 0.1s; }

    /* Feature card micro-animations */

    /* 1. Bar chart grows */
    .anim-bars .bar {
      transition: height 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .anim-bars:hover .bar-1 { height: 70%; }
    .anim-bars:hover .bar-2 { height: 100%; }
    .anim-bars:hover .bar-3 { height: 50%; }
    .anim-bars:hover .bar-4 { height: 85%; }

    /* 2. Checkmark appears */
    .anim-check .checkmark {
      transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
      transform: scale(0);
      opacity: 0;
    }
    .anim-check:hover .checkmark {
      transform: scale(1);
      opacity: 1;
    }

    /* 3. Lock clicks shut */
    .anim-lock .shackle {
      transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
      transform-origin: right bottom;
      transform: rotate(-30deg);
    }
    .anim-lock:hover .shackle {
      transform: rotate(0deg);
    }

    /* 4. Card flip */
    .anim-flip .flipper {
      transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
      transform-style: preserve-3d;
    }
    .anim-flip:hover .flipper {
      transform: rotateY(180deg);
    }
    .flip-front, .flip-back {
      backface-visibility: hidden;
    }
    .flip-back {
      transform: rotateY(180deg);
    }

    /* 5. Countdown tick */
    @keyframes tick {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.3; }
    }
    .anim-clock:hover .tick-digit {
      animation: tick 0.8s ease-in-out infinite;
    }
    .anim-clock:hover .tick-digit:nth-child(2) { animation-delay: 0.15s; }
    .anim-clock:hover .tick-digit:nth-child(3) { animation-delay: 0.3s; }

    /* 6. QR assembles */
    .anim-qr .qr-cell {
      transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
      opacity: 0.15;
      transform: scale(0.5);
    }
    .anim-qr:hover .qr-cell {
      opacity: 1;
      transform: scale(1);
    }
    .anim-qr:hover .qr-cell:nth-child(1) { transition-delay: 0.00s; }
    .anim-qr:hover .qr-cell:nth-child(2) { transition-delay: 0.03s; }
    .anim-qr:hover .qr-cell:nth-child(3) { transition-delay: 0.06s; }
    .anim-qr:hover .qr-cell:nth-child(4) { transition-delay: 0.09s; }
    .anim-qr:hover .qr-cell:nth-child(5) { transition-delay: 0.12s; }
    .anim-qr:hover .qr-cell:nth-child(6) { transition-delay: 0.15s; }
    .anim-qr:hover .qr-cell:nth-child(7) { transition-delay: 0.18s; }
    .anim-qr:hover .qr-cell:nth-child(8) { transition-delay: 0.21s; }
    .anim-qr:hover .qr-cell:nth-child(9) { transition-delay: 0.24s; }

    /* Feature card base */
    .feat-card {
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .feat-card:hover {
      transform: translateY(-4px);
    }

    /* Arrow pulse */
    @keyframes arrowPulse {
      0%, 100% { opacity: 0.4; }
      50% { opacity: 1; }
    }
    .arrow-pulse {
      animation: arrowPulse 2s ease-in-out infinite;
    }

    /* Grid pattern background */
    .grid-bg {
      background-image:
        linear-gradient(currentColor 0.5px, transparent 0.5px),
        linear-gradient(90deg, currentColor 0.5px, transparent 0.5px);
      background-size: 48px 48px;
      background-position: -0.25px -0.25px;
    }

    /* Timeline connector */
    .timeline-line {
      background: linear-gradient(90deg, var(--tw-gradient-from), var(--tw-gradient-to));
    }

    /* Scrollbar hide for horizontal scroll */
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  </style>
</head>
<body class="bg-zinc-50 dark:bg-zinc-950 text-zinc-900 dark:text-zinc-100 font-sans antialiased overflow-x-hidden">

