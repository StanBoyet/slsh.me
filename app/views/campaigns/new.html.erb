<% content_for :title, "New campaign — slsh.me" %>

<div class="max-w-xl mx-auto space-y-6">
  <div>
    <%= link_to links_path, class: "text-xs text-zinc-400 hover:text-zinc-700 dark:hover:text-zinc-200" do %>← Back<% end %>
    <h1 class="text-2xl font-semibold tracking-tight mt-2">New campaign</h1>
    <p class="text-sm text-zinc-500 mt-1">Pick a name and color. You'll set the destination URL and channels next.</p>
  </div>

  <%= form_with model: @campaign, class: "card p-6 space-y-5", data: { controller: "slugify" } do |f| %>
    <% if @campaign.errors.any? %>
      <div class="bg-red-50 border border-red-200 dark:bg-red-500/10 dark:border-red-500/20 rounded-xl px-4 py-3 text-sm text-red-700 dark:text-red-300 space-y-1">
        <% @campaign.errors.full_messages.each do |msg| %>
          <p>• <%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <div>
      <%= f.label :name, "Campaign name", class: "label" %>
      <%= f.text_field :name, placeholder: "e.g. Q2 Product Launch", required: true, autofocus: true,
          class: "input",
          data: { slugify_target: "source", action: "blur->slugify#fillIfEmpty" } %>
    </div>

    <div>
      <%= f.label :slug, "URL slug", class: "label" %>
      <%= f.text_field :slug, placeholder: "auto from name", class: "input font-mono text-sm",
          data: { slugify_target: "target" } %>
      <p class="text-xs text-zinc-400 mt-1">Used as <code>utm_campaign</code> on every link in this campaign.</p>
    </div>

    <div>
      <span class="label">Color</span>
      <div class="flex items-center gap-2">
        <% Campaign::COLORS.each do |color| %>
          <label class="cursor-pointer">
            <%= f.radio_button :color, color, class: "sr-only peer" %>
            <span class="block w-7 h-7 rounded-full <%= campaign_bg_class(color) %> peer-checked:ring-2 <%= campaign_ring_class(color) %> ring-offset-2 dark:ring-offset-zinc-900 transition-all"></span>
          </label>
        <% end %>
      </div>
    </div>

    <div class="flex items-center gap-3 pt-2">
      <%= link_to "Cancel", links_path, class: "btn-secondary" %>
      <%= f.submit "Create campaign", class: "btn-primary" %>
    </div>
  <% end %>
</div>
