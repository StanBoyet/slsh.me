<% content_for :title, "#{@campaign.name} — slsh.me" %>

<div class="space-y-6">
  <%# Header %>
  <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4">
    <div class="flex items-center gap-3">
      <%= link_to links_path, class: "btn-ghost p-1.5" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
      <% end %>
      <div>
        <div class="flex items-center gap-2.5">
          <span class="w-2.5 h-2.5 rounded-full <%= campaign_bg_class(@campaign.color) %> shrink-0"></span>
          <h1 class="text-xl font-semibold"><%= @campaign.name %></h1>
        </div>
        <p class="text-sm text-zinc-500 mt-0.5">
          <code class="text-xs"><%= @campaign.slug %></code>
          &middot; <%= @total_links %> link<%= "s" unless @total_links == 1 %>
          &middot; Created <%= @campaign.created_at.strftime("%b %d, %Y") %>
        </p>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to new_link_path(campaign_id: @campaign.id), class: "btn-primary text-xs" do %>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
        Add link
      <% end %>
    </div>
  </div>

  <%# Range selector %>
  <div class="flex items-center gap-2">
    <span class="section-title">Period:</span>
    <% [["7d", "7 days"], ["30d", "30 days"], ["90d", "90 days"]].each do |value, label| %>
      <%= link_to label, campaign_path(@campaign, range: value),
          class: "text-xs px-3 py-1.5 rounded-lg transition-colors #{@range == value ? 'bg-orange-500 text-white' : 'bg-zinc-100 text-zinc-600 hover:text-zinc-800 dark:bg-zinc-800 dark:text-zinc-400 dark:hover:text-zinc-200'}" %>
    <% end %>
  </div>

  <%# Rollup stats %>
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
    <div class="stat-card">
      <p class="text-xs text-zinc-500">Total clicks</p>
      <p class="text-2xl font-semibold tabular-nums"><%= number_with_delimiter(@total_clicks) %></p>
    </div>
    <div class="stat-card">
      <p class="text-xs text-zinc-500">Period clicks</p>
      <p class="text-2xl font-semibold tabular-nums"><%= number_with_delimiter(@period_clicks) %></p>
    </div>
    <div class="stat-card">
      <p class="text-xs text-zinc-500">Links</p>
      <p class="text-2xl font-semibold tabular-nums"><%= @total_links %></p>
    </div>
    <div class="stat-card">
      <p class="text-xs text-zinc-500">Top country</p>
      <% if @top_country %>
        <p class="text-2xl font-semibold"><%= @top_country[0] || "—" %></p>
        <p class="text-xs text-zinc-400"><%= number_with_delimiter(@top_country[1]) %> clicks</p>
      <% else %>
        <p class="text-2xl font-semibold text-zinc-300 dark:text-zinc-700">—</p>
      <% end %>
    </div>
  </div>

  <%# Source breakdown %>
  <% if @by_source.any? %>
    <div class="card p-5">
      <h3 class="section-title mb-4">Clicks by source</h3>
      <% max_clicks = @by_source.map(&:last).max %>
      <div class="space-y-3">
        <% @by_source.each do |source, count| %>
          <% pct = @period_clicks > 0 ? (count * 100.0 / @period_clicks).round : 0 %>
          <div class="flex items-center gap-3">
            <span class="text-sm font-medium w-24 truncate font-mono"><%= source %></span>
            <div class="flex-1 h-7 bg-zinc-100 dark:bg-zinc-800 rounded-lg overflow-hidden relative">
              <div class="h-full bg-orange-500 rounded-lg transition-all" style="width: <%= max_clicks > 0 ? (count * 100.0 / max_clicks).round : 0 %>%"></div>
              <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs font-medium tabular-nums text-zinc-600 dark:text-zinc-400"><%= number_with_delimiter(count) %></span>
            </div>
            <span class="text-xs text-zinc-400 w-10 text-right tabular-nums"><%= pct %>%</span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Campaign links %>
  <div>
    <h3 class="section-title mb-3">Campaign links</h3>
    <% if @links.any? %>
      <div class="space-y-2">
        <% @links.each do |link| %>
          <% utm_params = extract_utm_display(link.original_url) %>
          <%= link_to analytics_link_path(link), class: "card block hover:border-zinc-300 dark:hover:border-zinc-700 transition-colors" do %>
            <div class="flex items-center gap-4 p-4">
              <div class="w-9 h-9 rounded-xl bg-zinc-100 border border-zinc-200 dark:bg-zinc-800 dark:border-zinc-700 flex items-center justify-center shrink-0 overflow-hidden">
                <img src="https://www.google.com/s2/favicons?domain=<%= URI.parse(link.original_url).host rescue '' %>&sz=32"
                     class="w-5 h-5" alt="" onerror="this.style.display='none'">
              </div>
              <div class="flex-1 min-w-0">
                <span class="font-mono text-sm font-medium text-orange-500 dark:text-orange-400"><%= link.domain_label %>/<%= link.slug %></span>
                <% if utm_params.any? %>
                  <div class="flex items-center gap-2 mt-0.5 text-xs text-zinc-400 flex-wrap">
                    <% utm_params.each_with_index do |(key, val), i| %>
                      <% if i > 0 %><span>&middot;</span><% end %>
                      <span class="font-mono"><%= key %>=<%= val %></span>
                    <% end %>
                  </div>
                <% end %>
              </div>
              <div class="text-right shrink-0">
                <p class="text-lg font-semibold tabular-nums"><%= number_with_delimiter(link.clicks_count) %></p>
                <p class="text-xs text-zinc-400">clicks</p>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="card p-12 text-center">
        <p class="text-zinc-500 dark:text-zinc-400">No links in this campaign yet.</p>
        <%= link_to new_link_path(campaign_id: @campaign.id), class: "btn-primary mt-4 inline-flex" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
          Create a link
        <% end %>
      </div>
    <% end %>
  </div>
</div>
