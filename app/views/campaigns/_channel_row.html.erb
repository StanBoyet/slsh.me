<%# Locals: row (hash with :id, :utm_source, :utm_medium, :slug, :short_url, :clicks, :destination_url) %>
<% channel = channel_for(row[:utm_source]) %>
<tr class="channel-row hover:bg-orange-50/40 dark:hover:bg-orange-500/5 transition-colors"
    data-channel-matrix-target="row"
    data-link-id="<%= row[:id] %>">
  <td class="py-2.5 pl-5 pr-3">
    <div class="flex items-center gap-2">
      <span class="w-7 h-7 rounded-lg <%= channel[:bg] %> <%= channel[:fg] %> flex items-center justify-center text-xs font-bold shrink-0"><%= channel[:icon] %></span>
      <span class="font-medium text-sm"><%= channel[:label] %></span>
    </div>
  </td>
  <td class="px-3"><input type="text" data-field="utm_source" value="<%= row[:utm_source] %>" placeholder="source" class="input text-xs font-mono py-1.5"></td>
  <td class="px-3"><input type="text" data-field="utm_medium" value="<%= row[:utm_medium] %>" placeholder="medium" class="input text-xs font-mono py-1.5"></td>
  <td class="px-3"><input type="text" data-field="slug"       value="<%= row[:slug] %>"       placeholder="auto" class="input text-xs font-mono py-1.5"></td>
  <td class="px-3">
    <% if row[:short_url].present? %>
      <div class="flex items-center gap-2">
        <span class="font-mono text-xs text-orange-500"><%= row[:short_url].sub(%r{\Ahttps?://}, "") %></span>
        <button type="button" class="btn-ghost p-1 text-xs"
                data-controller="copy" data-copy-text-value="<%= row[:short_url] %>"
                data-action="click->copy#copy" title="Copy">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
        </button>
      </div>
    <% else %>
      <span class="text-xs italic text-zinc-400">— generated on save —</span>
    <% end %>
  </td>
  <td class="px-3 text-right tabular-nums font-medium text-sm"><%= row[:clicks].to_i.zero? ? content_tag(:span, "—", class: "text-zinc-300") : number_with_delimiter(row[:clicks]) %></td>
  <td class="px-2 text-right">
    <button type="button" class="btn-ghost p-1 text-zinc-300 hover:text-red-500 text-base leading-none"
            data-action="click->channel-matrix#removeRow" title="Remove">×</button>
  </td>
</tr>
