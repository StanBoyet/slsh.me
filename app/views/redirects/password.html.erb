<% content_for :title, "Protected link — slsh.me" %>
<div class="min-h-screen flex items-center justify-center px-4">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <div class="w-14 h-14 rounded-2xl bg-zinc-100 border border-zinc-200 dark:bg-zinc-800 dark:border-zinc-700 flex items-center justify-center mx-auto mb-4">
        <svg class="w-7 h-7 text-orange-400 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
      </div>
      <h1 class="text-xl font-semibold text-zinc-900 dark:text-white">Password required</h1>
      <p class="text-zinc-500 dark:text-zinc-400 text-sm mt-1">This link is password protected.</p>
    </div>

    <%= form_with url: unlock_redirect_path(slug: @link.slug), method: :post,
        class: "card p-6 space-y-4", data: { turbo: false } do |f| %>
      <% if flash[:alert] %>
        <div class="bg-red-50 border border-red-200 dark:bg-red-500/10 dark:border-red-500/20 rounded-lg px-3 py-2 text-sm text-red-700 dark:text-red-300">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <div>
        <%= f.label :password, "Password", class: "label" %>
        <%= f.password_field :password, required: true, autofocus: true,
            class: "input", placeholder: "Enter password" %>
      </div>

      <%= f.submit "Unlock", class: "btn-primary w-full justify-center py-2.5" %>
    <% end %>
  </div>
</div>
