<% content_for :title, "Link gone — slsh.me" %>
<div class="min-h-screen flex items-center justify-center px-4">
  <div class="text-center max-w-sm">
    <div class="text-7xl mb-6">🪦</div>
    <h1 class="text-2xl font-semibold text-slate-900 dark:text-white">This link has been slsh'd</h1>
    <p class="text-slate-500 dark:text-slate-400 text-sm mt-2">It was archived, expired, or otherwise sent to the great URL graveyard in the sky.</p>
    <p class="text-slate-400 dark:text-slate-600 text-xs mt-4 font-mono italic">"Not all who wander are lost — but this link definitely is."</p>
    <%= link_to root_path, class: "btn-primary mt-8 inline-flex" do %>
      <span>Take me home</span>
    <% end %>
  </div>
</div>
