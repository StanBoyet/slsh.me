<% content_for :title, "Link unavailable — slsh.me" %>
<div class="min-h-screen flex items-center justify-center px-4">
  <div class="text-center max-w-sm">
    <div class="text-6xl mb-6">✂️</div>
    <h1 class="text-2xl font-semibold text-slate-900 dark:text-white">This link has been snipped</h1>
    <p class="text-slate-500 dark:text-slate-400 text-sm mt-2">Looks like this short link is no longer active. The good news? You can make your own.</p>
    <p class="text-slate-400 dark:text-slate-600 text-xs mt-4 font-mono italic">"Life's too short for long URLs — and apparently for this one too."</p>
    <%= link_to root_path, class: "btn-primary mt-8 inline-flex" do %>
      Create your own short links
    <% end %>
  </div>
</div>
