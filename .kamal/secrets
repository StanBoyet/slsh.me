# Secrets are loaded by Kamal via dotenv. DO NOT check raw credentials into git.
# Every value here either reads from a local file, the shell env, or a password manager.

# GHCR push/pull token — reuses your gh CLI auth.
KAMAL_REGISTRY_PASSWORD=$(gh config get -h github.com oauth_token)

# Rails master key for credential decryption.
RAILS_MASTER_KEY=$(cat config/master.key)

# Postgres password. File is git-ignored; keep a copy in 1Password.
POSTGRES_PASSWORD=$(cat .kamal/.postgres_password)

# DATABASE_URL resolves the accessory hostname inside the Kamal Docker network.
DATABASE_URL="postgres://slsh_me:${POSTGRES_PASSWORD}@slsh-me-db:5432/slsh_me_production"
