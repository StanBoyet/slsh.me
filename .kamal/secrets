# Secrets are loaded by Kamal via dotenv. DO NOT check raw credentials into git.
# Each line prefers the env var (set by GitHub Actions) and falls back to a
# local source (gh CLI / config files) so the same file works in both contexts.
# Kamal's dotenv parser supports `$(...)` command substitution but NOT bash's
# `${VAR:-default}` form, hence the `test -n … && echo … || …` pattern.

# GHCR token. CI: GITHUB_TOKEN, scoped via `permissions: packages: write`.
# Local: gh CLI's cached token.
KAMAL_REGISTRY_PASSWORD=$(test -n "$KAMAL_REGISTRY_PASSWORD" && echo "$KAMAL_REGISTRY_PASSWORD" || gh config get -h github.com oauth_token)

# Rails master key. CI: set via `RAILS_MASTER_KEY` secret.
# Local: read from config/master.key (gitignored).
RAILS_MASTER_KEY=$(test -n "$RAILS_MASTER_KEY" && echo "$RAILS_MASTER_KEY" || cat config/master.key)

# Postgres password. CI: set via `POSTGRES_PASSWORD` secret.
# Local: read from .kamal/.postgres_password (gitignored; mirror to 1Password).
POSTGRES_PASSWORD=$(test -n "$POSTGRES_PASSWORD" && echo "$POSTGRES_PASSWORD" || cat .kamal/.postgres_password)

# DATABASE_URL resolves the accessory hostname inside the Kamal Docker network.
DATABASE_URL="postgres://slsh_me:${POSTGRES_PASSWORD}@slsh-me-db:5432/slsh_me_production"
